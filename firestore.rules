rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
        (request.auth.token.email == "v.suvania@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
        data.name is string &&
        data.role in ['Admin', 'Supervisor', 'Technician', 'Resident', 'Maid'];
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && 
        (request.resource.data.role == 'Resident' || request.resource.data.get('isDemo', false) == true);
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidComplaint(data) {
      return data.id is string &&
        data.title is string &&
        data.status in ['pending', 'in-progress', 'resolved'];
    }

    function isValidTimelineEvent(data) {
      return data.status is string &&
        data.title is string &&
        data.timestamp is number;
    }

    match /complaints/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComplaint(request.resource.data);
      allow update: if isAuthenticated() && isValidComplaint(request.resource.data);
      allow delete: if isAdmin();

      match /timeline/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidTimelineEvent(request.resource.data);
      }
    }
  }
}
